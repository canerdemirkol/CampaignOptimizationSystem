# ============================================================
# Campaign Optimization System - Python Service Environment Variables
# ============================================================

# Logging Level
LOG_LEVEL=INFO

# File Logging (default: false)
# Set to true to enable file-based logging alongside ECS console logging
# Docker/ECS: false (logs collected from stdout by OpenSearch)
# IIS/On-Premise: true (logs written to ./logs/ directory)
FILE_LOG_ENABLED=false

# Optimization Solver Time Limit (seconds)
# Default: 3600 (1 hour)
OPTIMIZATION_TIME_LIMIT=21600  # 6 saat — biraz pay bırak
# veya satırı sil → kod None geçer, solver süresiz çalışır

# Backend Service URL (for callbacks and authentication)
# Docker: http://campaign-backend:3001
# Local: http://localhost:3001
BACKEND_URL=http://localhost:3001

# Encryption Key (must match backend's ENCRYPTION_KEY)
# Minimum: 32 characters
# Must be the SAME as ENCRYPTION_KEY in backend/.env
ENCRYPTION_KEY="b14ca5898a4e4142aace2ea2143a2410"

# Service-to-service Authentication
# These credentials are used by Python service to authenticate with Backend
# For production: Use encrypted values (format: ENC:base64_encrypted_value)
# Use encrypt_credentials.py script to encrypt these values
SERVICE_USERNAME=admin
SERVICE_PASSWORD=admin123

# Host and Port Configuration
HOST=0.0.0.0
PORT=8000
