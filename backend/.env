# ============================================================
# Campaign Optimization System - Backend Environment Variables
# ============================================================
#
# KURULUM:
# 1. Bu dosyayı kopyala: cp .env.example .env
# 2. .env'i kendi ortamına göre düzenle
# 3. PLAINTEXT değerleri gir, şifreleme istersen:
#    npm run encrypt-env
#    → DATABASE_URL ve JWT_SECRET otomatik şifrelenir (ENC: prefix eklenir)
# 4. Uygulama başlatıldığında ENC: prefix'li değerler
#    CryptoService tarafından otomatik decrypt edilir
#
# ============================================================

# Database Configuration
# For Docker: DATABASE_URL is set via docker-compose.yml environment, no need to set here.
# For Local development: set your local PostgreSQL connection string below.
DATABASE_URL="ENC:m0YLlBxEj4HDYirZDaQF54q2t4PfRw2qAmAkSp9yZ/hWSV3dncGWPfzrmfUfbw5210uYlSXDfZk4G8V59gNH+N+Wyeb+55+ZY6TfBSMhsYA3kEw6u4CofbU04+v0o0vWqiavRdXmgo0yBelo6MYRClUNdyw5"


# JWT Secret (15+ characters recommended)
# Change this to a strong, random value in production!
JWT_SECRET="ENC:38DoT9qGoh3Mav1z4jmbPCwCrn+SFZ+EAlHPZ1IKwoyiKMx3uHYlKqtm9OTyumbFinPJDlH9tMdq4rsLwS8Te9MXAkqGeuPb88GG5BLixRiY/A=="

# AES-256 Encryption Key (exactly 32 characters, required for sensitive data)
# This is the MASTER KEY, stays in plaintext
# Minimum: 32 characters
ENCRYPTION_KEY="b14ca5898a4e4142aace2ea2143a2410"

# FastAPI Service URL (for optimization requests)
# Docker: http://campaign-python:8000
# Local: http://localhost:8000
FASTAPI_URL="http://localhost:8000"

# Frontend URL (for CORS configuration)
# Docker: http://campaign-frontend
# Local: http://localhost:5173
FRONTEND_URL="http://localhost:5173"

# Server Configuration
PORT=3001
NODE_ENV=development

# Logging (optional)
# LOG_LEVEL=INFO

# File Logging (default: false)
# Set to true to enable file-based logging alongside ECS console logging
# Docker/ECS: false (logs collected from stdout by OpenSearch)
# IIS/On-Premise: true (logs written to ./logs/ directory)
FILE_LOG_ENABLED=false
